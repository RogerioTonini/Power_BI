# =============================================================================
# .gitattributes - Configurações Git para Projetos Multi-Stack
# Tecnologias: C#, Python, JavaScript, HTML, CSS, PowerShell, Bash, SQL
# =============================================================================

# -----------------------------------------------------------------------------
# Auto-normalização de finais de linha (padrão para todos os arquivos)
# -----------------------------------------------------------------------------
* text=auto

# -----------------------------------------------------------------------------
# C# / .NET
# -----------------------------------------------------------------------------
*.cs text eol=lf diff=csharp
*.csx text eol=lf diff=csharp
*.vb text eol=lf
*.fs text eol=lf
*.fsx text eol=lf

# Arquivos de projeto e solução
*.csproj text eol=lf
*.sln text eol=lf merge=union
*.vbproj text eol=lf
*.vcxproj text eol=lf
*.vcproj text eol=lf
*.dbproj text eol=lf
*.fsproj text eol=lf

# Configurações .NET
*.config text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.nuspec text eol=lf
packages.config text eol=lf
App.config text eol=lf
Web.config text eol=lf

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
*.py text eol=lf diff=python
*.pyi text eol=lf diff=python
*.pyx text eol=lf
*.pxd text eol=lf
*.pyw text eol=lf

# Configurações Python
pyproject.toml text eol=lf
setup.py text eol=lf
setup.cfg text eol=lf
requirements*.txt text eol=lf
Pipfile text eol=lf
poetry.lock text eol=lf -diff
*.whl binary

# Jupyter Notebooks
*.ipynb text eol=lf

# -----------------------------------------------------------------------------
# JavaScript / TypeScript / Node.js
# -----------------------------------------------------------------------------
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf diff=typescript
*.tsx text eol=lf diff=typescript
*.mjs text eol=lf
*.cjs text eol=lf

# Configurações JavaScript/Node
package.json text eol=lf
package-lock.json text eol=lf -diff
yarn.lock text eol=lf -diff
.nvmrc text eol=lf
.npmrc text eol=lf
.yarnrc text eol=lf

# React/Vue/Angular
*.vue text eol=lf
*.svelte text eol=lf

# Minificados (não mostrar diff)
*.min.js -diff linguist-generated
*.min.css -diff linguist-generated
*.bundle.js -diff linguist-generated

# -----------------------------------------------------------------------------
# HTML / CSS / Web
# -----------------------------------------------------------------------------
*.html text eol=lf diff=html
*.htm text eol=lf diff=html
*.xhtml text eol=lf
*.shtml text eol=lf

*.css text eol=lf diff=css
*.scss text eol=lf
*.sass text eol=lf
*.less text eol=lf
*.styl text eol=lf

# Web fonts
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.otf binary

# -----------------------------------------------------------------------------
# PowerShell
# -----------------------------------------------------------------------------
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf
*.ps1xml text eol=crlf
*.pssc text eol=crlf
*.psrc text eol=crlf
*.cdxml text eol=crlf

# -----------------------------------------------------------------------------
# Bash / Shell Scripts
# -----------------------------------------------------------------------------
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf
*.ksh text eol=lf

# Arquivos sem extensão (shebangs Unix)
Makefile text eol=lf
Dockerfile text eol=lf
Rakefile text eol=lf
Vagrantfile text eol=lf
.bashrc text eol=lf
.bash_profile text eol=lf
.zshrc text eol=lf

# -----------------------------------------------------------------------------
# Windows Scripts
# -----------------------------------------------------------------------------
*.bat text eol=crlf
*.cmd text eol=crlf

# -----------------------------------------------------------------------------
# SQL / Databases
# -----------------------------------------------------------------------------
*.sql text eol=lf
*.ddl text eol=lf
*.dml text eol=lf
*.pls text eol=lf
*.plsql text eol=lf
*.prc text eol=lf
*.proc text eol=lf
*.sp text eol=lf

# Database binários
*.db binary
*.sqlite binary
*.sqlite3 binary
*.mdb binary
*.accdb binary
*.bak binary

# -----------------------------------------------------------------------------
# Configurações Gerais
# -----------------------------------------------------------------------------
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.env text eol=lf
.editorconfig text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# -----------------------------------------------------------------------------
# Documentação
# -----------------------------------------------------------------------------
*.md text eol=lf diff=markdown
*.markdown text eol=lf diff=markdown
*.rst text eol=lf
*.txt text eol=lf
*.adoc text eol=lf
*.textile text eol=lf

LICENSE text eol=lf
README text eol=lf
CHANGELOG text eol=lf
CONTRIBUTING text eol=lf
AUTHORS text eol=lf

# Marcar como documentação no GitHub
docs/** linguist-documentation
*.md linguist-documentation
*.rst linguist-documentation

# -----------------------------------------------------------------------------
# Templates
# -----------------------------------------------------------------------------
*.mustache text eol=lf
*.hbs text eol=lf
*.handlebars text eol=lf
*.ejs text eol=lf
*.jade text eol=lf
*.pug text eol=lf
*.tpl text eol=lf

# -----------------------------------------------------------------------------
# Dados
# -----------------------------------------------------------------------------
*.csv text eol=lf
*.tsv text eol=lf
*.tab text eol=lf

# -----------------------------------------------------------------------------
# Imagens
# -----------------------------------------------------------------------------
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.bmp binary
*.tiff binary
*.tif binary
*.webp binary
*.svg text eol=lf
*.svgz binary
*.ai binary
*.psd binary
*.eps binary

# -----------------------------------------------------------------------------
# Vídeo e Áudio
# -----------------------------------------------------------------------------
*.mp4 binary
*.mov binary
*.avi binary
*.mkv binary
*.webm binary
*.mp3 binary
*.wav binary
*.ogg binary
*.flac binary

# -----------------------------------------------------------------------------
# Documentos
# -----------------------------------------------------------------------------
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
*.odt binary
*.ods binary
*.odp binary

# -----------------------------------------------------------------------------
# Arquivos Comprimidos
# -----------------------------------------------------------------------------
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary
*.rar binary
*.tgz binary
*.tar.gz binary

# -----------------------------------------------------------------------------
# Executáveis e Binários
# -----------------------------------------------------------------------------
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.lib binary
*.a binary
*.o binary
*.obj binary
*.class binary
*.jar binary
*.war binary
*.ear binary
*.pyc binary
*.pyo binary

# -----------------------------------------------------------------------------
# Certificados e Chaves
# -----------------------------------------------------------------------------
*.cer binary
*.crt binary
*.der binary
*.p7b binary
*.p7c binary
*.pfx binary
*.p12 binary
*.key binary
*.pem text eol=lf
*.pub text eol=lf

# -----------------------------------------------------------------------------
# Controle de Linguagem no GitHub (Linguist)
# -----------------------------------------------------------------------------
# Excluir de estatísticas
vendor/** linguist-vendored
third_party/** linguist-vendored
node_modules/** linguist-vendored
packages/** linguist-vendored
lib/** linguist-vendored

# Marcar como gerados
**/migrations/* linguist-generated
**/dist/* linguist-generated
**/build/* linguist-generated
**/bin/* linguist-generated
**/obj/* linguist-generated
*.Designer.cs linguist-generated
*.designer.cs linguist-generated
*.g.cs linguist-generated
*.g.i.cs linguist-generated

# -----------------------------------------------------------------------------
# Export Ignore (não incluir em releases/archives)
# -----------------------------------------------------------------------------
.gitignore export-ignore
.gitattributes export-ignore
.editorconfig export-ignore
.github/ export-ignore
.vscode/ export-ignore
.idea/ export-ignore
.vs/ export-ignore
tests/ export-ignore
test/ export-ignore
docs/ export-ignore
*.md export-ignore
Makefile export-ignore
Rakefile export-ignore
.travis.yml export-ignore
.gitlab-ci.yml export-ignore
azure-pipelines.yml export-ignore
.circleci/ export-ignore
.dockerignore export-ignore

# -----------------------------------------------------------------------------
# Merge Strategies
# -----------------------------------------------------------------------------
# Changelog sempre usar união (combinar ambas versões)
CHANGELOG.md merge=union
CHANGELOG.txt merge=union

# Lock files - sempre pegar a versão "nossa"
*.lock merge=ours
package-lock.json merge=ours
yarn.lock merge=ours
poetry.lock merge=ours
